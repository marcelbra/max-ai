# Database Configuration (Local PostgreSQL via Homebrew)
# For local dev, use your system username with no password
DATABASE_URL=postgresql+asyncpg://${USER}@localhost:5432/maxai

# Application Configuration
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# OpenAI (for Phase 2+)
# OPENAI_API_KEY=your-api-key-here

# LangWatch (for Phase 2+)
# LANGWATCH_API_KEY=your-api-key-here
