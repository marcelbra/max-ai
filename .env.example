# Anthropic
MAX_AI_ANTHROPIC_API_KEY=sk-ant-...

# Model settings (optional)
# MAX_AI_MODEL=claude-sonnet-4-6
# MAX_AI_MAX_TOKENS=4096

# Database (default: SQLite at ~/.max-ai/max_ai.db)
# MAX_AI_DATABASE_URL=sqlite+aiosqlite:///~/.max-ai/max_ai.db
# MAX_AI_DATABASE_URL=postgresql+asyncpg://user@localhost:5432/maxai

# Spotify (optional — run `make setup-spotify` after setting these)
# MAX_AI_SPOTIFY_CLIENT_ID=...
# MAX_AI_SPOTIFY_CLIENT_SECRET=...
# MAX_AI_SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# LangWatch (optional — phase 2)
# MAX_AI_LANGWATCH_API_KEY=sk-lw-...
